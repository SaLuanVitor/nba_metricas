# ============================================
# ENVIRONMENT - Docker
# ============================================
NODE_ENV=production
USE_MOCK_DATA=false

# ============================================
# DATABASE - PostgreSQL
# ============================================
DATABASE_URL="postgresql://postgres:postgres@db:5432/nba_metricas"

# ============================================
# AUTH - NextAuth.js
# ============================================
NEXTAUTH_SECRET="change-this-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# NBA APIs
# ============================================
SPORTSDATA_API_KEY="your-api-key-here"
SPORTSDATA_API_URL="https://api.sportsdataapi.com"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://redis-cache:6379"

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info