# ============================================
# RAILWAY / PRODUCTION (EXAMPLE)
# ============================================
NODE_ENV=production

# --------------------------------------------
# Auth (required)
# --------------------------------------------
AUTH_SECRET=change-this-to-a-long-random-secret
MASTER_EMAIL=master@example.com
MASTER_PASSWORD=change-this-master-password
MASTER_NAME=Master User

# Optional OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR_PUBLIC_DOMAIN/api/auth/google/callback

# --------------------------------------------
# Database (required for auth/learning)
# Railway provides this in the Postgres service
# --------------------------------------------
DATABASE_URL=postgresql://postgres:password@HOST:5432/railway

# --------------------------------------------
# Data providers
# --------------------------------------------
# Strongly recommended in production
BALLDONTLIE_API_KEY=

# Optional fallbacks
BOLTODDS_API_KEY=
NBA_STATS_BASE_URL=https://stats.nba.com/stats
NBA_STATS_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
NBA_STATS_REFERER=https://www.nba.com/
NBA_STATS_TIMEOUT_MS=10000

# --------------------------------------------
# Resilience / Snapshot / Sync controls
# --------------------------------------------
SYNC_ADMIN_SECRET=change-this-sync-secret
CRON_REFRESH_SECRET=change-this-cron-secret
SYNC_THROTTLE_MS=60000
BALLDONTLIE_RATE_LIMIT_COOLDOWN_MS=300000
RESILIENCE_BREAKER_FAILURE_THRESHOLD=3
RESILIENCE_BREAKER_BASE_COOLDOWN_MS=60000
RESILIENCE_BREAKER_MAX_COOLDOWN_MS=900000
RESILIENCE_BUDGET_NBA_STATS_PER_MIN=120
RESILIENCE_BUDGET_BALLDONTLIE_PER_MIN=60
RESILIENCE_BUDGET_BOLTODDS_PER_MIN=60

# --------------------------------------------
# App behavior
# --------------------------------------------
APP_TIMEZONE=America/Bahia
NBA_SEASON=2025-26
STATUS_CONFIDENCE_MIN_SAFE=70
STATUS_CONFIDENCE_TARGET=80

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=info
