# Environment Variables

# ============================================
# DATABASE - Vercel Postgres
# ============================================
# Obtenha em: https://vercel.com/docs/storage/vercel-postgres
DATABASE_URL="postgres://default:password@host.cloud.vercel-postgres.com/verceldb"

# ============================================
# AUTH
# ============================================
# Segredo para assinar cookie de sessão
AUTH_SECRET="change-this-secret"

# Master bootstrap (nao versionar valores reais)
MASTER_EMAIL="master@example.com"
MASTER_PASSWORD="change-this-password"
MASTER_NAME="Master User"

# OAuth Providers (opcional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ============================================
# NBA DATA APIs
# ============================================
# BallDontLie API - https://balldontlie.io (FREE TIER: 30 req/min)
# Sign up for free API key
BALLDONTLIE_API_KEY=""

# NBA Stats API (stats.nba.com)
# Used as primary for players/teams/games in hybrid mode
NBA_STATS_BASE_URL="https://stats.nba.com/stats"
NBA_STATS_USER_AGENT=""
NBA_STATS_REFERER="https://www.nba.com/"
NBA_STATS_TIMEOUT_MS=10000

# BoltOdds API - https://boltodds.com/docs
# Focus: odds, games metadata, boxscores/live feeds (not full player season averages)
BOLTODDS_API_KEY=""

# Timezone da aplicação para cálculo de "hoje" em endpoints de jogos/schedule
APP_TIMEZONE="America/Bahia"

# Temporada alvo (opcional)
NBA_SEASON="2025-26"


# ============================================
# CACHE - Vercel KV (Redis)
# ============================================
# Obtenha em: https://vercel.com/docs/storage/vercel-kv
KV_URL="redis://default:password@host.cloud.vercel-storage.com"
KV_REST_API_URL="https://host.cloud.vercel-storage.com"
KV_REST_API_TOKEN="your-kv-token"

# ============================================
# ANALYTICS
# ============================================
# Vercel Analytics (jÃ¡ instalado)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV="development"

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="debug"
LOG_PRETTY=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ============================================
# ML/AI CONFIG
# ============================================
# Pasta para modelos treinados (se necessÃ¡rio)
MODELS_PATH="./models"
AI_CONFIDENCE_THRESHOLD=65

# ============================================
# EXTERNAL SERVICES
# ============================================
# Webhook para atualizaÃ§Ãµes em tempo real (opcional)
WEBHOOK_SECRET=""

# ============================================
# ============================================

# Debug mode
DEBUG=false

